<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="10dp"
    app:cardBackgroundColor="@color/bg_card"
    app:cardCornerRadius="12dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/divider"
    app:strokeWidth="1dp"
    android:clickable="true" android:focusable="true">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="14dp">
        <FrameLayout android:id="@+id/fileIconBg" android:layout_width="42dp" android:layout_height="42dp" android:background="@drawable/bg_tool_icon" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent">
            <ImageView android:id="@+id/fileTypeIcon" android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@drawable/ic_files" android:tint="@color/neon_primary"/>
        </FrameLayout>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:orientation="vertical" android:layout_marginStart="12dp" android:layout_marginEnd="8dp" app:layout_constraintStart_toEndOf="@id/fileIconBg" app:layout_constraintEnd_toStartOf="@id/btnMore" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent">
            <TextView android:id="@+id/tvFileName" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="decrypted_message.txt" android:textColor="@color/text_primary" android:textSize="14sp" android:textStyle="bold"/>
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" android:layout_marginTop="2dp">
                <TextView android:id="@+id/tvFileSize" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="3.12 KB" android:textColor="@color/text_secondary" android:textSize="12sp"/>
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="  •  " android:textColor="@color/text_hint" android:textSize="12sp"/>
                <TextView android:id="@+id/tvFileDate" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="28/05/2024 12:30" android:textColor="@color/text_secondary" android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>
        <ImageButton android:id="@+id/btnMore" android:layout_width="28dp" android:layout_height="28dp" android:background="?attr/selectableItemBackgroundBorderless" android:src="@drawable/ic_more" android:contentDescription="More" app:layout_constraintEnd_toEndOf="parent" app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
