<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.DragonicDecryptor" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/neon_primary</item>
        <item name="colorOnPrimary">@color/bg_primary</item>
        <item name="colorPrimaryContainer">@color/neon_dim</item>
        <item name="colorOnPrimaryContainer">@color/neon_primary</item>
        <item name="colorSecondary">@color/neon_blue</item>
        <item name="colorOnSecondary">@color/bg_primary</item>
        <item name="colorTertiary">@color/neon_purple</item>
        <item name="colorSurface">@color/bg_secondary</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_card</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>
        <item name="colorError">@color/status_error</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/nav_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="Theme.DragonicDecryptor.Splash" parent="Theme.DragonicDecryptor">
        <item name="android:windowFullscreen">true</item>
    </style>

    <!-- Neon Button style -->
    <style name="Widget.Dragonic.Button.Neon" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/neon_primary</item>
        <item name="android:textColor">@color/bg_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

    <style name="Widget.Dragonic.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/neon_primary</item>
        <item name="android:textColor">@color/neon_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.Dragonic.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/bg_card</item>
        <item name="cardElevation">0dp</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="strokeColor">@color/glass_border</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="TextAppearance.Dragonic.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <style name="TextAppearance.Dragonic.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Dragonic.Neon" parent="TextAppearance.Material3.TitleSmall">
        <item name="android:textColor">@color/neon_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.1</item>
    </style>

</resources>
